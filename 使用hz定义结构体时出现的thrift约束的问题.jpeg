// CreateStudent .
// @router /student [POST]
func CreateStudent(ctx context.Context, c *app.RequestContext) {
	var err error
	var req student.CreateStudentReq
	// 强制绑定JSON，跳过thrift解析
	err = c.BindJSON(&req)
	if err != nil {
		c.String(consts.StatusBadRequest, err.Error())
		return
	}

	// 手动校验参数
	if req.Name == "" {
		c.String(consts.StatusBadRequest, "Name cannot be empty")
		return
	}
	if req.Age <= 0 || req.Age > 100 {
		c.String(consts.StatusBadRequest, "Age must be between 1 and 100")
		return
	}

	// 调用数据访问层创建学生
	std, err := mysql.CreateStudent(&req)
	if err != nil {
		c.String(consts.StatusInternalServerError, err.Error())
		return
	}

	resp := new(student.CommonResp)
	resp.Code = int32(consts.StatusOK)
	resp.Message = "创建成功"
	resp.Data = std
	c.JSON(consts.StatusOK, resp)
}

使用bindAndVaild方法就会出错，BindJSON就不会 但是基础示例的gorm代码可以使用
